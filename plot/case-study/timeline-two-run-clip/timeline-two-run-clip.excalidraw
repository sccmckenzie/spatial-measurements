    {
      "id": "el-1658",
      "type": "text",
      "x": 164,
      "y": 470,
      "width": 500.50000000000006,
      "height": 65,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1658,
      "version": 2,
      "versionNonce": 1980236343,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784405509391,
      "link": null,
      "locked": false,
      "text": "W-103 / W-104 were still writing at Run 1, so they were held back.\nRun 1 advanced the watermark to W-102's last write. At Run 2 they've\nsettled — but the filter admits only modified_at > watermark, so every\nrecord written before it is never re-scanned. Silently dropped.",
      "originalText": "W-103 / W-104 were still writing at Run 1, so they were held back.\nRun 1 advanced the watermark to W-102's last write. At Run 2 they've\nsettled — but the filter admits only modified_at > watermark, so every\nrecord written before it is never re-scanned. Silently dropped.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "containerId": null,
      "lineHeight": 1.25,
